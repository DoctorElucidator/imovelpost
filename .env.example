# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string
# Local example: postgresql://postgres:postgres@localhost:5432/imovelpost
# Replit: set via the Database integration panel
DATABASE_URL=postgresql://user:password@localhost:5432/imovelpost

# OpenAI API key — used server-side only for post generation and market analysis
OPENAI_API_KEY=sk-...

# Port the API server listens on (defaults to 8080 if not set)
PORT=8080
